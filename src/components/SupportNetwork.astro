---
const supportItems = [
	['Bienestar universitario', 'Espacio institucional para orientación, programas de promoción y acompañamiento.', '[xdxd]'],
	['Orientación psicológica', 'Canal para solicitar apoyo cuando la carga emocional o académica sea difícil de manejar.', '[Agregar correo institucional]'],
	['Docentes y consejeros académicos', 'Personas que pueden orientar sobre rutas académicas, entregas, procesos y alternativas.', '[Agregar contacto o dependencia]'],
	['Representantes estudiantiles', 'Vocería para compartir inquietudes colectivas y conocer canales de participación.', '[Agregar enlace o nombre de representación]'],
	['Amigos y familiares', 'Red cercana para conversar, pedir apoyo práctico y no atravesar la presión en soledad.', '[Agregar recomendación interna]'],
	['Líneas de atención', 'Rutas externas o institucionales que deben verificarse con fuentes oficiales.', '[Agregar número de contacto]'],
];
---

<section id="apoyo" class="section section-tint" aria-labelledby="support-title">
	<div class="container">
		<div class="section-heading reveal">
			<p class="eyebrow">Red de apoyo</p>
			<h2 id="support-title">Pedir ayuda también es una estrategia de bienestar</h2>
			<p>Estos datos están marcados para edición. Agrega únicamente canales oficiales confirmados por la Universidad Distrital.</p>
		</div>
		<div class="card-grid">
			{supportItems.map(([title, text, placeholder]) => (
				<article class="support-card reveal">
					<h3>{title}</h3>
					<p>{text}</p>
					<span>{placeholder}</span>
				</article>
			))}
		</div>
		<div class="center reveal">
			<a class="button button-primary" href="#apoyo">Consultar rutas de apoyo</a>
		</div>
	</div>
</section>
